# Backend selection — one of: ollama (default), transformers, vllm
AYU_BACKEND=ollama

# Hugging Face style id; the Ollama backend auto-maps to gemma4:<size>
AYU_MODEL_ID=google/gemma-4-E4B-it

# Where Ollama is running
AYU_OLLAMA_HOST=http://localhost:11434

# If using vLLM
AYU_VLLM_BASE_URL=http://localhost:8000/v1
AYU_VLLM_API_KEY=token-ayuconnect

# Generation
AYU_TEMPERATURE=0.4
AYU_MAX_NEW_TOKENS=768
AYU_TOOL_LOOP_BUDGET=4

# CORS (JSON-encoded list of allowed origins for the Next.js frontend)
AYU_ALLOW_ORIGINS=["http://localhost:3000"]
